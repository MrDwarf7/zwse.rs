# Remove Cargo.lock from gitignore if creating a library; keep it for binaries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

.idea/
.idea/*
.idea/**/*

# Local dumps / session fixtures (may contain browsing history, cookies, URLs)
current_win.txt
dump.txt
*.jsonlz4
sessionstore*
workspace_export*.txt
*_good.*
*_operations.*
.extras/
./.extras/
